{
  "name": "flowpilot",
  "version": "0.1.0",
  "description": "A pluggable frontend guidance SDK for step-by-step user training.",
  "type": "module",
  "main": "dist/flowpilot.umd.js",
  "module": "dist/flowpilot.esm.js",
  "unpkg": "dist/flowpilot.umd.js",
  "jsdelivr": "dist/flowpilot.umd.js",
  "scripts": {
    "build": "vite build",
    "build:min": "cross-env MINIFY=true vite build",
    "build:all": "node scripts/build-all.mjs",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "keywords": [
    "guide",
    "onboarding",
    "tutorial",
    "frontend",
    "plugin",
    "sdk"
  ],
  "author": "FlowPilot Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "terser": "^5.46.1",
    "vite": "^5.2.0"
  }
}
