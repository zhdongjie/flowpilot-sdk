{
  "workflow": {
    "id": "open_account",
    "steps": [
      {
        "step": 1,
        "page": "/home",
        "type": "form",
        "highlight": "ui.form_login",
        "action": "Validate login form",
        "behavior": {
          "type": "form",
          "completion": {
            "type": "event",
            "name": "login_form_filled"
          }
        }
      },
      {
        "step": 2,
        "page": "/home",
        "type": "form",
        "highlight": "ui.btn_login",
        "action": "Submit login",
        "behavior": {
          "type": "form",
          "completion": {
            "type": "event",
            "name": "login_success"
          }
        }
      },
      {
        "step": 3,
        "page": "/home",
        "type": "route",
        "highlight": "ui.btn_login",
        "action": "Navigate to customer center",
        "behavior": {
          "type": "route",
          "completion": {
            "type": "event",
            "name": "route_to_customer"
          }
        }
      },
      {
        "step": 4,
        "page": "/customer",
        "type": "click",
        "highlight": "ui.menu_open_account",
        "action": "Click Open Account"
      },
      {
        "step": 5,
        "page": "/customer",
        "type": "route",
        "highlight": "ui.menu_open_account",
        "action": "Navigate to account form page",
        "behavior": {
          "type": "route",
          "completion": {
            "type": "event",
            "name": "route_to_customer_create"
          }
        }
      },
      {
        "step": 6,
        "page": "/customer/create",
        "type": "form",
        "highlight": "ui.form_open_account",
        "action": "Validate account opening form",
        "behavior": {
          "type": "form",
          "completion": {
            "type": "event",
            "name": "open_account_form_filled"
          }
        }
      },
      {
        "step": 7,
        "page": "/customer/create",
        "type": "form",
        "highlight": "ui.btn_submit_application",
        "action": "Submit and wait for successful API response",
        "behavior": {
          "type": "form",
          "completion": {
            "type": "event",
            "name": "open_account_submit_success"
          }
        }
      }
    ]
  },
  "mapping": {
    "ui.form_login": {
      "selector": "[data-guide-id='ui.form_login']"
    },
    "ui.btn_login": {
      "selector": "[data-guide-id='ui.btn_login']"
    },
    "ui.menu_open_account": {
      "selector": "[data-guide-id='ui.menu_open_account']"
    },
    "ui.form_open_account": {
      "selector": "[data-guide-id='ui.form_open_account']"
    },
    "ui.btn_submit_application": {
      "selector": "[data-guide-id='ui.btn_submit_application']"
    }
  }
}
