{
  "workflow": {
    "id": "open_account",
    "steps": [
      {
        "id": "step_login_submit",
        "type": "form",
        "highlight": "ui.form_login",
        "desc": "Submit the login form to enter customer service center"
      },
      {
        "id": "step_menu_open_account",
        "type": "click",
        "highlight": "ui.menu_open_account",
        "desc": "Choose Open Account after arriving at customer service center"
      },
      {
        "id": "step_submit_application",
        "type": "form",
        "highlight": "ui.form_open_account",
        "desc": "Submit the account opening form for review"
      }
    ]
  },
  "mapping": {
    "ui.form_login": {
      "selector": "[data-guide-id='ui.form_login']",
      "pages": ["/home"]
    },
    "ui.menu_open_account": {
      "selector": "[data-guide-id='ui.menu_open_account']",
      "pages": ["/customer"]
    },
    "ui.form_open_account": {
      "selector": "[data-guide-id='ui.form_open_account']",
      "pages": ["/customer/create"]
    }
  }
}
